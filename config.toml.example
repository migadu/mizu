server = []
local = false

[defaults]
hostname = "mail.example.com"
max_message_size = 26214400
timeout_seconds = 10
shutdown_timeout_seconds = 60
max_connections = 100

[logging]
level = "info"
format = "console"
output = "syslog"

[dns]
resolvers = []
timeout_seconds = 5
cache_ttl_seconds = 300
cache_negative_ttl = 60

[storage]
backend = "s3"
filesystem_path = "/var/lib/mizu/storage"
s3_endpoint = "s3.amazonaws.com"
s3_bucket = "email-mx-certs"
s3_prefix = ""
s3_access_key = ""
s3_secret_key = ""
s3_region = "us-east-1"

[tls]
enabled = false
provider = "file"
[tls.file]
cert_file = ""
key_file = ""
[tls.letsencrypt]
email = "admin@example.com"
domains = []
default_domain = ""
storage_provider = "s3"
cache_dir = ""
sync_interval_minutes = 5
staging = false
renew_before_days = 30
[tls.letsencrypt.s3]
bucket = ""
region = ""
endpoint = ""
prefix = ""
access_key = ""
secret_key = ""

[health]
enabled = true
listen_addr = ":8080"
username = ""
password = ""

[metrics]
enabled = true
bind = ":9091"
path = "/metrics"
username = ""
password = ""

[stats]
enabled = true
retention_seconds = 86400
sync_enabled = false
sync_interval_seconds = 60
max_ip_entries = 100000
max_domain_entries = 50000
buffer_size = 100000

[cluster]
enabled = false
addr = ""
port = 7946
node_name = ""
peers = []
secret_key = ""
